__pycache__/
*.pyc
venv/

# Real config holds this robot's actual IP addresses — see config.yaml.example
config.yaml

# Runtime-generated, device-specific — not source
manager/config-backup/
oxts-nav/xnav-config/
*.log

# Camera calibration — device/lens-specific, see camera/camera-prd.md
shared/camera-cal.yaml
camera/data/

# Surveyed marker positions — this robot's real-world data, see aruco-prd.md
aruco/data/

# Compiled firmware artifacts — a build output, not source; the .ino is
# the source of truth, see drive-prd.md
drive/firmware/*.hex

# Claude Code's own local tooling state, not project source
.claude/
