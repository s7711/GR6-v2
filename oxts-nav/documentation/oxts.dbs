{
    "$schema": "DBS.schema.json",
    "DBSDescription": "The available signals that are available to be output",
    "DBSID": "OXTS_DBS",
    "DBSName": "2026-04-07",
    "UCOMVersion": 1,
    "Sources": [
        {
            "SourceID": "TIME",
            "SourceName": "Time stamp source",
            "SourceDescription": "The resolved time stamps signals",
            "SignalsInSource": [
                {
                    "SignalID": "Nano",
                    "SignalName": "GNSS Time",
                    "SignalDescription": "The time according to the GNSS sources (previously GNSST)",
                    "Category": "Time",
                    "NativeType": "S64",
                    "NativeUnit": "s",
                    "UnitMagnitude": "n",
                    "IntroducedInVersion": 0
                },
                {
                    "SignalID": "SDNOFF",
                    "SignalName": "SDN Time Offset",
                    "SignalDescription": "Offset from SDN time. First part of the signal is an Enum giving the offset source (byte 1). Second part is the offset in nano seconds (bytes 2-9). This signal cannot be added to any custom messages",
                    "Category": "Time",
                    "NativeType": "EnS64",
                    "EnumValues": {
                        "0": "Time Source None",
                        "1": "Time Source Gnss",
                        "2": "Time Source Ptp",
                        "3": "Time Source Ext Gnss",
                        "4": "Time Source User",
                        "5": "Time Source Gad"
                    },
                    "NativeUnit": "s",
                    "UnitMagnitude": "n",
                    "IntroducedInVersion": 1
                },
                {
                    "SignalID": "UpTime",
                    "SignalName": "System up time",
                    "SignalDescription": "Time since power applied and system booted",
                    "Category": "Advanced",
                    "NativeType": "S32",
                    "NativeUnit": "s",
                    "UnitMagnitude": "-",
                    "IntroducedInVersion": 1
                },
                {
                    "SignalID": "NanoFromInit",
                    "SignalName": "Time from initialisation",
                    "SignalDescription": "Time from initialisation",
                    "Category": "Time",
                    "NativeType": "S64",
                    "NativeUnit": "s",
                    "UnitMagnitude": "n",
                    "IntroducedInVersion": 1
                }
            ]
        },
        {
