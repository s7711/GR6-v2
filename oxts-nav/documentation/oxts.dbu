                    "Unit": "-",
                    "EnumValues": {
                        "0": "Navigation Status Invalid",
                        "1": "Navigation Status RawImu",
                        "2": "Navigation Status Init",
                        "3": "Navigation Status Locking",
                        "4": "Navigation Status Locked",
                        "5": "Navigation Status Unlocked",
                        "6": "Navigation Status Expired",
                        "7": "Navigation Status Blocked",
                        "8": "Navigation Status Reserved 08",
                        "9": "Navigation Status Reserved 09",
                        "10": "Navigation Status Statusonly",
                        "11": "Navigation Status Extra",
                        "12": "Navigation Status Locked Survey",
                        "13": "Navigation Status Reserved 13",
                        "14": "Navigation Status Reserved 14",
                        "15": "Navigation Status Reserved 15",
                        "16": "Navigation Status Reserved 16",
                        "17": "Navigation Status Reserved 17",
                        "18": "Navigation Status Reserved 18",
                        "19": "Navigation Status Reserved 19",
                        "20": "Navigation Status Triginit",
                        "21": "Navigation Status Triglocking",
                        "22": "Navigation Status Triglocked"
                    }
                }
            ]
        },
