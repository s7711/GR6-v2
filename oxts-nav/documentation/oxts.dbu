{
    "$schema": "DBU.schema.json",
    "DBUDescription": "The OXTS DBU with all the OXTS defined messages",
    "DBUID": "OXTS_DBU",
    "DBUName": "2026-04-07",
    "UCOMVersion": 1,
    "PossibleTriggerTypes": {
        "0": "No Trigger",
        "1": "In 1 Down",
        "2": "In 1 Up",
        "3": "Out 1",
        "4": "In 2 Down",
        "5": "In 2 Up",
        "6": "Unknown 1",
        "7": "Unknown 2",
        "8": "Out 2"
    },
    "PossibleHeaderTiming": {
        "0": "SDN",
        "1": "GNSS"
    },
    "Messages": [
        {
            "FrequencyOutputType": "IMU",
            "IntroducedInVersion": 0,
            "MessageDescription": "Heartbeat message with meta information about the INS",
            "MessageEnabled": true,
            "MessageID": 0,
            "MessageName": "Heartbeat",
            "MessageSchemaVersion": 2,
            "MessageTiming": "SDN",
            "MessageVersion": 0,
            "OutputFrequencyDecimation": 1,
            "OutputType": "FrequencyBased",
            "SignalsInMessage": [
                {
                    "SignalID": "SerialNumber",
                    "SourceID": "META",
                    "DataType": "U32",
                    "Offset": 0.0,
                    "ScaleFactor": 1.0,
                    "Unit": "-"
                }
            ]
        },
        {
            "IntroducedInVersion": 1,
            "MessageDescription": "The time offsets from the SDN time in the header to the time in the message payload described by the enum value: byte 1 of the payload is the enum value and bytes 2-9 are the offset value",
            "MessageEnabled": true,
            "MessageID": 100,
            "MessageName": "The SDN time offsets",
            "MessageSchemaVersion": 2,
            "MessageTiming": "SDN",
            "MessageVersion": 0,
            "OutputType": "OnChange",
            "SignalsInMessage": [
                {
                    "SignalID": "SDNOFF",
                    "SourceID": "TIME",
                    "DataType": "EnS64",
                    "Offset": 0.0,
                    "ScaleFactor": 1000000000.0,
                    "Unit": "s",
                    "EnumValues": {
                        "0": "Time Source None",
                        "1": "Time Source Gnss",
                        "2": "Time Source Ptp",
                        "3": "Time Source Ext Gnss",
                        "4": "Time Source User",
                        "5": "Time Source Gad"
                    }
                }
            ]
        },
        {
            "IntroducedInVersion": 1,
            "MessageDescription": "The current INS navigation status from the blended navigation system",
            "MessageEnabled": false,
            "MessageID": 54,
            "MessageName": "INS Status",
            "MessageSchemaVersion": 2,
            "MessageTiming": "SDN",
            "MessageVersion": 0,
            "OutputType": "FrequencyBased",
