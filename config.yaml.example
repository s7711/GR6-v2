# Shared runtime config for GR6-v2 — single source of truth for every
# service's systemd unit name, web UI host/port, and icon.
# See top-prd.md ("Shared configuration") and manager/manager-prd.md.
#
# Copy this file to config.yaml and fill in real values — config.yaml
# itself is gitignored since it holds this robot's real IP address.

xnav_ip: 192.168.0.0  # placeholder — set to the real xNAV650 IP

services:
  manager:
    unit: robot-manager.service
    host: 0.0.0.0
    port: 8000
    web_ui: true

  hello:
    unit: robot-hello.service
    host: 0.0.0.0
    port: 8001
    web_ui: true

  oxts-nav:
    unit: robot-oxts-nav.service
    host: 0.0.0.0
    port: 8002
    web_ui: true
    nav_update_hz: 2
    nav_feed_socket: /tmp/gr6-oxts-nav-feed.sock  # Unix domain socket — see "Nav data feed" in oxts-nav-prd.md
    nav_feed_hz: 20
    hpr_ib: [-90, 90, 0]  # IMU-to-body mounting (mobile.vat) — read by aruco too, for GAD lever-arm/alignment frames

  camera:
    unit: robot-camera.service
    host: 0.0.0.0
    port: 8003
    web_ui: true
    camera_fps: 5  # Resolution is fixed (1280x960), not configurable — see camera-prd.md
    camera_shm_name: gr6-camera-frame

  aruco:
    unit: robot-aruco.service
    host: 0.0.0.0
    port: 8004
    web_ui: true
    marker_map_file: aruco/data/marker-map.yaml
    camera_extrinsics:
      hpr_cb: [0, 0, 0]  # camera mount HPR relative to body; unmeasured/assumed — see aruco-prd.md bore-sight note
      d_xc_b: [0.0775, 0.002, -0.07]  # camera displacement in body frame, metres

  drive:
    unit: robot-drive.service
    host: 0.0.0.0
    port: 8005
    web_ui: true
    serial_port: /dev/ttyUSB0       # re-check once the Pico is fitted — likely /dev/ttyACM0 or similar
    baud: 115200
    counts_per_metre: 250            # from GR6-v1, needs re-measuring on this robot — the wheelspeed-GAD sender will depend on this being right
    human_control_hold_ms: 500       # how long a manual jog command locks out automatic callers (navigate/missions) — see drive-prd.md
    expected_firmware_version: "260720#1.GR6"
    drive_feed_socket: /tmp/gr6-drive-feed.sock  # Unix domain socket — see "Feed naming" in drive-prd.md
    drive_feed_hz: 20
    tuning: {}                        # optional, e.g. {Kp: [1.0, 1.0], Ki: [3.0, 3.0]} — pushed to the microcontroller each time drive starts
